# ── ezone environment variables ───────────────────────────────────────────────
# Copy this file to .env and fill in your values before running docker compose.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ezone
POSTGRES_USER=ezone
POSTGRES_PASSWORD=change_me_in_production

# ── Server ────────────────────────────────────────────────────────────────────
# Port to expose on the host
EZONE_PORT=8080

# Worker threads (default: 4)
EZONE_THREADS=4

# The frontend URL — used to build magic link URLs in emails
EZONE_APP_URL=https://yourapp.com

# CORS origin — set to your frontend origin, e.g. https://yourapp.com
# Leave blank to disable CORS headers (server-to-server mode)
EZONE_CORS_ORIGIN=https://yourapp.com

# Auth endpoint rate limit (requests per IP per minute, 0 = disabled)
EZONE_RATE_LIMIT=60

# ── Email ─────────────────────────────────────────────────────────────────────
# "log"    — print magic links to stdout (development only)
# "resend" — send real emails via Resend API (production)
EZONE_EMAIL_PROVIDER=resend

# Required when EZONE_EMAIL_PROVIDER=resend
EZONE_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EZONE_EMAIL_FROM=ezone <auth@yourapp.com>

# Optional email subject overrides
# EZONE_SUBJECT_REGISTER=Complete your registration
# EZONE_SUBJECT_LOGIN=Your sign-in link
# EZONE_SUBJECT_RESET=Reset your account
# EZONE_SUBJECT_ADD_DEVICE=Approve new device

# ── TLS (optional — recommended in production) ────────────────────────────────
# Place your PEM cert and key in a ./certs/ directory and set paths.
# With a reverse proxy (nginx, Caddy), leave these blank — let the proxy handle TLS.
# EZONE_CERT_DIR=./certs
# EZONE_TLS_CERT=/certs/fullchain.pem
# EZONE_TLS_KEY=/certs/privkey.pem

# ── PostgreSQL connection pool ────────────────────────────────────────────────
EZONE_DB_POOL_SIZE=8
