{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "NodeNext",
    "moduleResolution":  "NodeNext",
    "lib":               ["ES2022", "DOM", "DOM.Iterable"],
    "outDir":            "./dist",
    "declaration":       true,
    "declarationMap":    true,
    "sourceMap":         true,
    "strict":            true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride":  true,
    "esModuleInterop":   true,
    "skipLibCheck":      true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
