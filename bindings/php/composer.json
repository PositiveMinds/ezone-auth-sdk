{
  "name":        "ezone/ezone-sdk",
  "description": "ezone passwordless authentication SDK for PHP",
  "type":        "library",
  "license":     "MIT",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": { "Ezone\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Ezone\\Tests\\": "tests/" }
  }
}
